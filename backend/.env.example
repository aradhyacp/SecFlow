# SecFlow — Root Environment Variables
# Copy to .env and fill in your actual keys.
#
# docker compose --env-file .env up --build

# ── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Optional analyzer API keys ───────────────────────────────────────────────
# Recon-Analyzer
NUMVERIFY_API_KEY=
THREATFOX_API_KEY=
ipAPI_KEY=

# ── Orchestrator settings ────────────────────────────────────────────────────
# Maximum analyzer passes per pipeline run: 3, 4, or 5 (default: 3)
MAX_PASSES=3

# ── Steg-Analyzer database password ─────────────────────────────────────────
# Change this in production — used for the steg-postgres container.
STEG_POSTGRES_PASSWORD=secflowpass
