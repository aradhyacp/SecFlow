{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecFlow PWNDoc Report",
  "type": "object",
  "required": ["input", "total_passes", "overall_risk_score", "summary", "passes", "recommendations"],
  "properties": {
    "input": {
      "type": "string",
      "description": "The original input that was analyzed (file path, URL, IP, or domain)"
    },
    "total_passes": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of analyzer passes that were completed"
    },
    "overall_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Aggregated risk score across all passes (0.0 – 10.0)"
    },
    "summary": {
      "type": "string",
      "description": "2-3 sentence executive summary of the analysis results"
    },
    "passes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass_number", "analyzer", "findings"],
        "properties": {
          "pass_number": { "type": "integer", "minimum": 1 },
          "analyzer": {
            "type": "string",
            "enum": ["malware", "steg", "recon", "web", "url", "classifier"]
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "detail", "severity"],
              "properties": {
                "type":     { "type": "string" },
                "detail":   { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low", "info"]
                },
                "evidence": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actionable remediation steps based on the findings"
    }
  }
}
