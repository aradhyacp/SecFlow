{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SecFlow PWNDoc Report",
  "type": "object",
  "required": ["input", "total_passes", "overall_risk_score", "summary", "passes", "recommendations"],
  "properties": {
    "input": {
      "type": "string",
      "description": "The original input that was analyzed (file path, URL, IP, or domain)"
    },
    "total_passes": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of analyzer passes that were completed"
    },
    "overall_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Aggregated risk score across all passes (0.0 – 10.0)"
    },
    "summary": {
      "type": "string",
      "description": "2-3 sentence executive summary of the analysis results"
    },
    "passes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass_number", "analyzer", "findings"],
        "properties": {
          "pass_number": { "type": "integer", "minimum": 1 },
          "analyzer": {
            "type": "string",
            "enum": ["malware", "steg", "recon", "web", "url", "classifier", "macro"]
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "detail", "severity"],
              "properties": {
                "type":     { "type": "string" },
                "detail":   { "type": "string" },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low", "info"]
                },
                "evidence": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actionable remediation steps based on the findings"
    },
    "threat_intel": {
      "type": "object",
      "description": "AI-generated threat intelligence: summary, YARA rules, SIGMA rules",
      "properties": {
        "model":     { "type": "string" },
        "error":     { "type": ["string", "null"] },
        "threat_summary": {
          "type": "object",
          "properties": {
            "threat_name":       { "type": "string" },
            "threat_actor_type": { "type": "string" },
            "attack_vector":     { "type": "string" },
            "attack_chain":      { "type": "array", "items": { "type": "string" } },
            "severity":          { "type": "string" },
            "confidence":        { "type": "string" },
            "reasoning":         { "type": "string" },
            "iocs": {
              "type": "object",
              "properties": {
                "hashes":     { "type": "array", "items": { "type": "string" } },
                "ips":        { "type": "array", "items": { "type": "string" } },
                "domains":    { "type": "array", "items": { "type": "string" } },
                "urls":       { "type": "array", "items": { "type": "string" } },
                "file_names": { "type": "array", "items": { "type": "string" } }
              }
            },
            "mitre_ttps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id":     { "type": "string" },
                  "name":   { "type": "string" },
                  "tactic": { "type": "string" }
                }
              }
            }
          }
        },
        "yara": {
          "type": "object",
          "properties": {
            "reasoning":   { "type": "string" },
            "total_rules": { "type": "integer" },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "rule_name":   { "type": "string" },
                  "description": { "type": "string" },
                  "reasoning":   { "type": "string" },
                  "tags":        { "type": "array", "items": { "type": "string" } },
                  "rule_text":   { "type": "string" }
                }
              }
            }
          }
        },
        "sigma": {
          "type": "object",
          "properties": {
            "reasoning":   { "type": "string" },
            "total_rules": { "type": "integer" },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "rule_name":   { "type": "string" },
                  "description": { "type": "string" },
                  "log_source":  { "type": "string" },
                  "reasoning":   { "type": "string" },
                  "rule_text":   { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
