# SecFlow Orchestrator — Environment Variables
#
# Copy this file to .env and fill in the values before running.

# ── Gemini AI (required) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Analyzer service URLs (Docker-internal defaults shown) ───────────────────
# Override when running outside Docker Compose (e.g. local testing).
MALWARE_ANALYZER_URL=http://malware-analyzer:5000/api/malware-analyzer
STEG_ANALYZER_URL=http://steg-analyzer:5000/api/steg-analyzer
RECON_ANALYZER_URL=http://recon-analyzer:5000/api/Recon-Analyzer
WEB_ANALYZER_URL=http://web-analyzer:5000/api/web-analyzer

# ── Orchestrator settings (optional) ─────────────────────────────────────────
# Maximum number of analyzer passes before the loop is forced to stop.
# Accepted values: 3, 4, or 5  (default 3)
MAX_PASSES=3
